---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** Relatief pad, bijv. "/diensten" — voor canonical/OG */
  path?: string;
  /** og:type — standaard "website", "article" voor artikelen. */
  ogType?: "website" | "article";
  /** Pad of URL naar een deelbare afbeelding (Open Graph). */
  image?: string;
  /** Sluit de pagina uit van indexering (bijv. concepten). */
  noindex?: boolean;
}

const {
  title = "Financieel-administratieve ondersteuning voor ondernemers",
  description = "Geborgd Advies ondersteunt ondernemers met financiële administratie, backoffice, financieel inzicht en HR-documentatie. Rustig, betrouwbaar en persoonlijk.",
  path = Astro.url.pathname,
  ogType = "website",
  image,
  noindex = false,
} = Astro.props;

const siteName = "Geborgd Advies";
const fullTitle = title.includes(siteName) ? title : `${title} — ${siteName}`;
const site = Astro.site ?? "https://www.geborgdadvies.nl";
const canonical = new URL(path, site).href;
const ogImage = image ? new URL(image, site).href : undefined;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#172033" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="nl_NL" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Geborgd Advies — Actueel & inzicht"
      href={new URL("/rss.xml", site).href}
    />

    <!-- Extra head-inhoud (bijv. structured data) -->
    <slot name="head" />

    <!-- Inter — enkel benodigde weights, non-blocking -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:text-white"
    >
      Naar hoofdinhoud
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
