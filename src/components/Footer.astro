---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Diensten",
    links: [
      { href: "/diensten#administratie", label: "Financiële administratie" },
      { href: "/diensten#backoffice", label: "Backoffice ondersteuning" },
      { href: "/diensten#inzicht", label: "Financieel inzicht" },
      { href: "/diensten#hr", label: "Beleid & HR-documentatie" },
    ],
  },
  {
    title: "Navigatie",
    links: [
      { href: "/werkwijze", label: "Werkwijze" },
      { href: "/over-edwin", label: "Over Edwin" },
      { href: "/contact", label: "Contact" },
    ],
  },
];
---

<footer class="mt-24 bg-primary text-white">
  <div class="container-x grid gap-10 py-14 md:grid-cols-4 md:gap-8">
    <div class="md:col-span-2 md:max-w-sm">
      <div class="flex items-center gap-2.5">
        <span class="grid h-9 w-9 place-items-center rounded-lg bg-primary-soft text-accent">
          <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
            <path d="M12 2 4 5.5v6c0 4.4 3.2 8.4 8 10.5 4.8-2.1 8-6.1 8-10.5v-6L12 2Z"
              stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
            <path d="m8.5 12 2.5 2.5 4.5-5" stroke="currentColor" stroke-width="1.8"
              stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="text-lg font-semibold tracking-tight">Geborgd Advies</span>
      </div>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-white/70">
        Financieel-administratieve ondersteuning voor ondernemers. Rustig,
        betrouwbaar en met oog voor uw hele organisatie.
      </p>

      <address class="mt-6 space-y-1.5 text-sm text-white/70 not-italic">
        <p>Hogebrinkerweg 15D<br />3871 KM Hoevelaken</p>
        <p>
          <a href="tel:+31651222705" class="transition-colors hover:text-accent">06 51 22 27 05</a>
        </p>
        <p>
          <a href="mailto:edwin@geborgdadvies.nl" class="transition-colors hover:text-accent">edwin@geborgdadvies.nl</a>
        </p>
      </address>
    </div>

    {columns.map((col) => (
      <nav aria-label={col.title}>
        <h2 class="text-xs font-semibold tracking-wider text-white/50 uppercase">{col.title}</h2>
        <ul class="mt-4 space-y-2.5">
          {col.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-white/80 transition-colors hover:text-accent">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ))}
  </div>

  <div class="border-t border-white/10">
    <div class="container-x flex flex-col gap-2 py-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {year} Geborgd Advies. Alle rechten voorbehouden.</p>
      <p>KvK 74839241</p>
    </div>
  </div>
</footer>
