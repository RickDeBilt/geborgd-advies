---
import BaseLayout from "../layouts/BaseLayout.astro";
import { services } from "../data/services";

// Het formulier post naar de eigen PHP-handler (public/contact.php),
// die via SMTP mailt naar edwin@geborgdadvies.nl.

const details = [
  {
    label: "Telefoon",
    value: "06 51 22 27 05",
    href: "tel:+31651222705",
    icon: "M4 5a2 2 0 0 1 2-2h2l2 5-2 1a11 11 0 0 0 5 5l1-2 5 2v2a2 2 0 0 1-2 2A16 16 0 0 1 4 5Z",
  },
  {
    label: "E-mail",
    value: "edwin@geborgdadvies.nl",
    href: "mailto:edwin@geborgdadvies.nl",
    icon: "M4 6h16v12H4V6Zm0 1 8 6 8-6",
  },
  {
    label: "Adres",
    value: "Hogebrinkerweg 15D, 3871 KM Hoevelaken",
    href: "https://maps.google.com/?q=Hogebrinkerweg+15D+3871+KM+Hoevelaken",
    icon: "M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Zm0-8.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z",
  },
  {
    label: "Bereikbaarheid",
    value: "Ma t/m vr, 09:00 – 17:00 · op afspraak",
    icon: "M12 7v5l3 2M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
  },
];
---

<BaseLayout
  title="Contact"
  description="Neem contact op met Geborgd Advies voor een vrijblijvende kennismaking. Bel, mail of laat uw gegevens achter — Edwin reageert snel."
  path="/contact"
>
  <section class="bg-primary text-white">
    <div class="container-x py-16 md:py-20">
      <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 text-xs font-medium tracking-wide text-accent uppercase">
        Contact
      </p>
      <h1 class="mt-6 max-w-2xl text-4xl leading-[1.1] font-semibold tracking-tight md:text-5xl">
        Laten we kennismaken
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/75">
        Een vrijblijvend gesprek kost u niets en levert vaak veel op. Bel, mail of
        laat uw gegevens achter — dan neem ik snel contact met u op.
      </p>
    </div>
  </section>

  <section class="container-x py-20 md:py-24">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <!-- Gegevens -->
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-primary">Direct contact</h2>
        <dl class="mt-8 space-y-6">
          {details.map((item) => (
            <div class="flex gap-4">
              <dt class="shrink-0">
                <span class="sr-only">{item.label}</span>
                <span class="grid h-11 w-11 place-items-center rounded-xl bg-accent-soft text-primary" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5">
                    <path d={item.icon} stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </dt>
              <dd>
                <span class="text-xs font-semibold tracking-wider text-muted uppercase">{item.label}</span>
                {item.href ? (
                  <a
                    href={item.href}
                    class="mt-0.5 block text-lg text-primary hover:text-accent-hover"
                    {...item.href.startsWith("http")
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {}}
                  >
                    {item.value}
                  </a>
                ) : (
                  <span class="mt-0.5 block text-lg text-primary">{item.value}</span>
                )}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Formulier -->
      <div class="rounded-2xl border border-border bg-surface p-8 md:p-10">
        <h2 class="text-2xl font-semibold tracking-tight text-primary">Stuur een bericht</h2>
        <p class="mt-2 text-sm text-muted">Vul het formulier in en ik reageer binnen één werkdag.</p>

        <form
          id="contact-form"
          class="mt-8 space-y-5"
          name="contact"
          method="POST"
          action="/api/contact.php"
        >
          <!-- Honeypot tegen spam: door mensen onzichtbaar, door bots vaak ingevuld -->
          <div class="hidden" aria-hidden="true">
            <label>Laat dit veld leeg
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="naam" class="block text-sm font-semibold text-text">Naam</label>
              <input
                type="text" id="naam" name="naam" required autocomplete="name"
                class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
              />
            </div>
            <div>
              <label for="bedrijf" class="block text-sm font-semibold text-text">Bedrijf</label>
              <input
                type="text" id="bedrijf" name="bedrijf" autocomplete="organization"
                class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
              />
            </div>
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-sm font-semibold text-text">E-mailadres</label>
              <input
                type="email" id="email" name="email" required autocomplete="email"
                class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
              />
            </div>
            <div>
              <label for="telefoon" class="block text-sm font-semibold text-text">Telefoon</label>
              <input
                type="tel" id="telefoon" name="telefoon" required autocomplete="tel"
                inputmode="tel" minlength="9"
                class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
              />
            </div>
          </div>
          <div>
            <label for="onderwerp" class="block text-sm font-semibold text-text">Waarover gaat het?</label>
            <select
              id="onderwerp" name="onderwerp"
              class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
            >
              {services.map((service) => <option>{service.title}</option>)}
              <option>Iets anders</option>
            </select>
          </div>
          <div>
            <label for="bericht" class="block text-sm font-semibold text-text">Bericht</label>
            <textarea
              id="bericht" name="bericht" rows="4" required
              class="mt-2 w-full rounded-lg border border-border bg-bg px-4 py-2.5 text-text transition-colors focus:border-accent focus:bg-surface"
            ></textarea>
          </div>

          <label class="flex items-start gap-3 text-sm text-muted">
            <input
              type="checkbox" name="akkoord" required
              class="mt-0.5 h-4 w-4 shrink-0 rounded border-border text-primary focus:ring-accent"
            />
            <span>
              Ik ga ermee akkoord dat mijn gegevens worden gebruikt om contact met
              mij op te nemen.
            </span>
          </label>

          <!-- Statusmelding (toegankelijk) -->
          <p id="form-status" role="status" aria-live="polite" class="hidden text-sm"></p>

          <button
            type="submit"
            id="submit-btn"
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-primary px-6 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
          >
            <span id="submit-label">Verstuur bericht</span>
            <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </form>

        <script>
          const form = document.getElementById("contact-form") as HTMLFormElement | null;
          const status = document.getElementById("form-status");
          const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
          const label = document.getElementById("submit-label");

          // Tijdstip waarop de pagina geladen werd — voor de minimale invultijd.
          const loadedAt = Date.now();

          function setStatus(message: string, ok: boolean) {
            if (!status) return;
            status.textContent = message;
            status.classList.remove("hidden");
            status.classList.toggle("text-red-600", !ok);
            status.classList.toggle("text-primary", ok);
          }

          form?.addEventListener("submit", async (event) => {
            event.preventDefault();
            if (!form.reportValidity()) return;

            const data = new FormData(form);
            data.append("elapsed", String(Date.now() - loadedAt));
            if (btn) btn.disabled = true;
            if (label) label.textContent = "Bezig met verzenden…";
            status?.classList.add("hidden");

            try {
              const res = await fetch("/api/contact.php", {
                method: "POST",
                headers: { Accept: "application/json" },
                body: data,
              });
              const result = await res.json();

              if (res.ok && result.success) {
                window.location.href = "/bedankt/";
                return;
              }
              setStatus(
                result.message ||
                  "Er ging iets mis bij het verzenden. Probeer het later opnieuw of mail direct naar edwin@geborgdadvies.nl.",
                false
              );
            } catch {
              setStatus(
                "Verzenden lukte niet. Controleer uw verbinding of mail direct naar edwin@geborgdadvies.nl.",
                false
              );
            } finally {
              if (btn) btn.disabled = false;
              if (label) label.textContent = "Verstuur bericht";
            }
          });
        </script>
      </div>
    </div>
  </section>
</BaseLayout>
