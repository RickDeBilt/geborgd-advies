---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import CTASection from "../components/CTASection.astro";

const steps = [
  {
    number: "01",
    title: "Vrijblijvende kennismaking",
    text: "We beginnen met een open gesprek over uw organisatie, uw administratie en waar ondersteuning gewenst is. Kosteloos en zonder verplichtingen — zodat u weet wat u aan ons heeft.",
  },
  {
    number: "02",
    title: "Inventarisatie",
    text: "We brengen uw huidige situatie en processen in kaart: wat loopt goed, waar zit werk en welke taken kunnen we overnemen. Zo ontstaat een helder vertrekpunt.",
  },
  {
    number: "03",
    title: "Voorstel op maat",
    text: "U ontvangt een concreet voorstel met duidelijke afspraken, verwachtingen en tarieven. Geen kleine lettertjes — u weet vooraf precies waar u aan toe bent.",
  },
  {
    number: "04",
    title: "Inrichten & overnemen",
    text: "We richten de samenwerking praktisch in en nemen de afgesproken taken zorgvuldig over. U wordt overal in meegenomen, zodat de overgang soepel verloopt.",
  },
  {
    number: "05",
    title: "Doorlopende ondersteuning",
    text: "Uw administratie blijft actueel en op orde. We houden regelmatig contact, denken mee en schakelen bij als uw organisatie verandert.",
  },
];

const promises = [
  "Vrijblijvend en kosteloos kennismakingsgesprek",
  "Heldere, vooraf afgesproken tarieven",
  "Eén vast en persoonlijk aanspreekpunt",
  "Zorgvuldige en vertrouwelijke omgang met uw gegevens",
];
---

<BaseLayout
  title="Werkwijze"
  description="Zo werkt Geborgd Advies: van een vrijblijvende kennismaking tot doorlopende, betrouwbare ondersteuning. Helder en transparant in vijf stappen."
  path="/werkwijze"
>
  <Hero
    eyebrow="Werkwijze"
    title="Een heldere aanpak, zonder verrassingen"
    subtitle="In vijf stappen van kennismaking naar betrouwbare ondersteuning. U weet bij elke stap precies wat u kunt verwachten."
    primaryCta={{ href: "/contact", label: "Zet de eerste stap" }}
    secondaryCta={{ href: "/diensten", label: "Bekijk de diensten" }}
  />

  <section class="container-x py-20 md:py-24" aria-label="Stappen">
    <div class="mx-auto max-w-3xl">
      <ol class="relative space-y-5 border-l border-border pl-8">
        {steps.map((step, i) => (
          <li class="relative scroll-mt-28">
            <span
              class="absolute -left-[2.55rem] grid h-8 w-8 place-items-center rounded-full bg-primary text-xs font-semibold text-accent"
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <div class="rounded-2xl border border-border bg-surface p-6">
              <div class="flex items-baseline gap-3">
                <span class="text-sm font-semibold text-accent-hover">{step.number}</span>
                <h2 class="text-xl font-semibold tracking-tight text-primary">{step.title}</h2>
              </div>
              <p class="mt-2.5 leading-relaxed text-muted">{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Transparantie -->
  <section class="bg-surface" aria-labelledby="afspraken-heading">
    <div class="container-x grid gap-10 py-20 md:py-24 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div>
        <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Transparant</p>
        <h2 id="afspraken-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
          Duidelijke afspraken, vooraf
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Vertrouwen begint bij duidelijkheid. Daarom bespreken we voordat we
          starten precies wat u kunt verwachten en wat het kost. Geen verrassingen
          achteraf.
        </p>
      </div>
      <ul class="grid gap-3">
        {promises.map((item) => (
          <li class="flex items-start gap-3 rounded-xl border border-border bg-bg p-4 text-text">
            <svg viewBox="0 0 20 20" fill="none" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true">
              <path d="m5 10 3.5 3.5L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="text-sm leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection />
</BaseLayout>
