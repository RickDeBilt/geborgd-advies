---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TrustBar from "../components/TrustBar.astro";
import ServiceCard from "../components/ServiceCard.astro";
import CTASection from "../components/CTASection.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { services } from "../data/services";
import { getPublishedArticles } from "../utils/articles";

const latestArticles = (await getPublishedArticles()).slice(0, 3);

const reasons = [
  {
    title: "Persoonlijk en betrokken",
    text: "U heeft één vast aanspreekpunt dat uw organisatie kent en met u meedenkt — geen wisselende contactpersonen.",
  },
  {
    title: "Rust en overzicht",
    text: "Uw administratie is op orde en actueel, zodat u altijd weet waar u staat en met een gerust hart onderneemt.",
  },
  {
    title: "Flexibel inzetbaar",
    text: "Van losse taken tot volledige backoffice: de ondersteuning past zich aan uw organisatie en processen aan.",
  },
  {
    title: "Zorgvuldig en discreet",
    text: "Uw gegevens zijn in vertrouwde handen. Nauwkeurigheid en vertrouwelijkheid staan bij elke opdracht voorop.",
  },
];

const steps = [
  { number: "01", title: "Kennismaking", text: "We bespreken vrijblijvend uw situatie en waar ondersteuning gewenst is." },
  { number: "02", title: "Voorstel op maat", text: "U ontvangt een helder voorstel met concrete afspraken en tarieven." },
  { number: "03", title: "Aan de slag", text: "We richten de samenwerking in en nemen de afgesproken taken over." },
  { number: "04", title: "Doorlopende ondersteuning", text: "U blijft op de hoogte en houdt grip, wij houden uw administratie actueel." },
];
---

<BaseLayout
  title="Financieel-administratieve ondersteuning voor ondernemers"
  description="Geborgd Advies ondersteunt ondernemers met financiële administratie, bank- en giroverwerking, backoffice, financieel inzicht en HR-documentatie. Rustig, betrouwbaar en persoonlijk."
  path="/"
>
  <Hero
    eyebrow="Financieel & administratief specialist"
    title="Financieel-administratieve ondersteuning waar u op kunt bouwen"
    subtitle="Geborgd Advies ontzorgt ondernemers met een accurate administratie, een betrouwbare backoffice en helder financieel inzicht. Zo houdt u tijd en rust over om te ondernemen."
    secondaryCta={{ href: "/diensten", label: "Bekijk de diensten" }}
  />

  <TrustBar />

  <!-- Diensten -->
  <section class="container-x py-20 md:py-24" aria-labelledby="diensten-heading">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Diensten</p>
      <h2 id="diensten-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
        Ondersteuning van administratie tot backoffice
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Van uw dagelijkse boekhouding tot beleidsstukken en HR-documentatie: één
        specialist die het overzicht bewaakt en werk uit handen neemt.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          summary={service.summary}
          icon={service.icon}
          href={`/diensten#${service.id}`}
        />
      ))}
    </div>
  </section>

  <!-- Waarom Geborgd Advies -->
  <section class="bg-surface" aria-labelledby="waarom-heading">
    <div class="container-x grid gap-12 py-20 md:py-24 lg:grid-cols-2 lg:items-start lg:gap-16">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Waarom Geborgd Advies</p>
        <h2 id="waarom-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
          Betrouwbare ondersteuning die begint bij luisteren
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Goede ondersteuning begint met begrip van uw organisatie. Wij nemen de
          tijd om uw situatie écht te doorgronden en werken vervolgens nauwkeurig,
          betrokken en vertrouwelijk.
        </p>
        <a
          href="/over-edwin"
          class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-accent-hover"
        >
          Maak kennis met Edwin
          <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
            <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <ul class="grid gap-5 sm:grid-cols-2">
        {reasons.map((reason) => (
          <li class="rounded-2xl border border-border bg-bg p-6">
            <span class="grid h-9 w-9 place-items-center rounded-full bg-primary text-accent">
              <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
                <path d="m5 10 3.5 3.5L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <h3 class="mt-4 text-base font-semibold tracking-tight text-primary">{reason.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted">{reason.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Werkwijze -->
  <section class="container-x py-20 md:py-24" aria-labelledby="werkwijze-heading">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Werkwijze</p>
      <h2 id="werkwijze-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
        Duidelijk, in vier stappen
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-muted">
        Een heldere aanpak zonder verrassingen. U weet bij elke stap precies waar
        u aan toe bent.
      </p>
    </div>

    <ol class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step) => (
        <li class="rounded-2xl border border-border bg-surface p-6">
          <span class="text-sm font-semibold text-accent-hover">{step.number}</span>
          <h3 class="mt-2 text-base font-semibold tracking-tight text-primary">{step.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted">{step.text}</p>
        </li>
      ))}
    </ol>

    <div class="mt-10">
      <a href="/werkwijze" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-accent-hover">
        Lees meer over de werkwijze
        <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
          <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Actueel -->
  {latestArticles.length > 0 && (
    <section class="bg-surface" aria-labelledby="actueel-heading">
      <div class="container-x py-20 md:py-24">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Actueel</p>
            <h2 id="actueel-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
              Inzicht voor uw onderneming
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-muted">
              Praktische uitleg over financiële, administratieve en personele
              ontwikkelingen die relevant zijn voor ondernemers.
            </p>
          </div>
          <a
            href="/actueel/"
            class="inline-flex shrink-0 items-center gap-2 self-start rounded-full border border-border px-5 py-2.5 text-sm font-semibold text-primary transition-colors hover:border-accent/60 hover:bg-bg sm:self-auto"
          >
            Bekijk alle artikelen
            <svg viewBox="0 0 20 20" fill="none" class="h-4 w-4" aria-hidden="true">
              <path d="M4 10h12m-5-5 5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {latestArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CTASection />
</BaseLayout>
