---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import edwinFoto from "../assets/edwin.jpg";

const values = [
  { title: "Nauwkeurig", text: "Een administratie die klopt tot in het detail. Zorgvuldigheid is de basis van vertrouwen." },
  { title: "Betrokken", text: "Uw organisatie is geen dossiernummer. Ik denk mee, ook als de vraag verder reikt dan de cijfers." },
  { title: "Discreet", text: "Vertrouwelijke informatie blijft vertrouwelijk. Daar mag u altijd op rekenen." },
];

const expertise = [
  "Financiële en administratieve ondersteuning",
  "Backoffice en organisatorische processen",
  "Beleidsstukken, arbeidscontracten en personeelshandboeken",
  "Begeleiding bij WIA- en IVA-trajecten",
];
---

<BaseLayout
  title="Over Edwin"
  description="Maak kennis met Edwin, de financieel en administratief specialist achter Geborgd Advies. Persoonlijk, nauwkeurig en betrokken."
  path="/over-edwin"
>
  <!-- Intro -->
  <section class="bg-primary text-white">
    <div class="container-x grid gap-12 py-20 md:py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3.5 py-1.5 text-xs font-medium tracking-wide text-accent uppercase">
          Over Edwin
        </p>
        <h1 class="mt-6 text-4xl leading-[1.1] font-semibold tracking-tight md:text-5xl">
          De specialist achter uw administratie
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-white/75">
          Ik ben Edwin, oprichter van Geborgd Advies. Als financieel en administratief
          specialist ondersteun ik ondernemers bij hun financiële administratie,
          backoffice en HR-documentatie — met oog voor detail en voor de mens
          achter de onderneming.
        </p>
        <p class="mt-4 leading-relaxed text-white/60">
          Geborgd Advies ontstond vanuit een heldere overtuiging: administratieve
          ondersteuning moet betrouwbaar, persoonlijk en rustgevend zijn. Geen
          onnodige complexiteit, maar iemand die naast u staat en werk uit handen neemt.
        </p>
      </div>

      <div class="relative">
        <div class="aspect-[4/5] overflow-hidden rounded-[1.5rem] border border-white/10 bg-primary-soft">
          <Image
            src={edwinFoto}
            alt="Edwin, financieel en administratief specialist en oprichter van Geborgd Advies"
            widths={[400, 640, 800]}
            sizes="(min-width: 1024px) 40vw, (min-width: 640px) 80vw, 100vw"
            class="h-full w-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Waarden -->
  <section class="container-x py-20 md:py-24" aria-labelledby="waarden-heading">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Waar ik voor sta</p>
      <h2 id="waarden-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
        Drie dingen waar u op kunt rekenen
      </h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {values.map((value) => (
        <div class="rounded-2xl border border-border bg-surface p-7">
          <h3 class="text-lg font-semibold tracking-tight text-primary">{value.title}</h3>
          <p class="mt-2.5 leading-relaxed text-muted">{value.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Expertise -->
  <section class="bg-surface" aria-labelledby="expertise-heading">
    <div class="container-x grid gap-10 py-20 md:py-24 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div>
        <p class="text-sm font-semibold tracking-wide text-accent-hover uppercase">Expertise</p>
        <h2 id="expertise-heading" class="mt-3 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
          Brede ervaring, één aanspreekpunt
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-muted">
          Doordat administratie, backoffice en HR-documentatie bij één specialist
          samenkomen, houdt u het overzicht en heeft u kort contact.
        </p>
      </div>
      <ul class="grid gap-3">
        {expertise.map((item) => (
          <li class="flex items-start gap-3 rounded-xl border border-border bg-bg p-4 text-text">
            <svg viewBox="0 0 20 20" fill="none" class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true">
              <path d="m5 10 3.5 3.5L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="text-sm leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Quote -->
  <section class="container-x py-20 md:py-24">
    <figure class="mx-auto max-w-3xl text-center">
      <svg viewBox="0 0 24 24" fill="currentColor" class="mx-auto h-9 w-9 text-accent" aria-hidden="true">
        <path d="M9 7H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2v2a2 2 0 0 1-2 2H4v2h1a4 4 0 0 0 4-4V7Zm11 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2v2a2 2 0 0 1-2 2h-1v2h1a4 4 0 0 0 4-4V7Z" />
      </svg>
      <blockquote class="mt-6 text-2xl leading-snug font-semibold tracking-tight text-primary md:text-3xl">
        "Goede ondersteuning begint niet bij de cijfers, maar bij de ondernemer.
        Pas als ik uw organisatie begrijp, kan ik u echt ontzorgen."
      </blockquote>
      <figcaption class="mt-6 text-sm font-semibold text-muted">
        Edwin — Geborgd Advies
      </figcaption>
    </figure>
  </section>

  <CTASection
    title="Even kennismaken?"
    text="Bel gerust of plan een kennismaking. Ik vertel u graag wat Geborgd Advies voor u kan betekenen."
  />
</BaseLayout>
